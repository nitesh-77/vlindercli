# =============================================================================
# Pensieve Agent - Default Configuration
# =============================================================================
# This is the compiled-in default configuration. Copy this to your Vlinderfile
# to customize the agent's behavior.

name = "pensieve"
description = "A memory system for web articles - save, search, and question your readings"
source = "agents/pensieve"

[requirements]
models = ["phi3", "nomic-embed"]
services = ["fetch_url", "store_file", "embed", "search_by_vector", "infer"]

# =============================================================================
# Prompts - Modify any section to override defaults
# =============================================================================
# All prompts use placeholders like {input}, {query}, {context}, etc.
# The agent will replace these with actual values at runtime.

[prompts]

# Intent recognition - determines what the user wants to do
intent_recognition = '''
{{ intent_recognition }}'''

# Query expansion - transforms short queries into richer search phrases
query_expansion = '''
{{ query_expansion }}'''

# Answer generation - synthesizes answers from retrieved memories
answer_generation = '''
{{ answer_generation }}'''

# Map summarize - extracts key points from each chunk
map_summarize = '''
{{ map_summarize }}'''

# Reduce summaries - combines chunk summaries into final briefing
reduce_summaries = '''
{{ reduce_summaries }}'''

# Direct summarize - for short content that doesn't need map-reduce
direct_summarize = '''
{{ direct_summarize }}'''
